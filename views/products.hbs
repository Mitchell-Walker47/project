<!-- Products Table Display -->
<h1>Products</h1>

<table>

    <thead>
        <tr>
            <th>productID</th>
            <th>productName</th>
            <th>category</th>
            <th>brand</th>
            <th>price</th>
            <th>stockQuantity</th>
            <th>description</th>
        </tr>
    </thead>

    <tbody>

        {{#each products}}
            <tr>
                <td>{{this.productID}}</td>
                <td>{{this.productName}}</td>
                <td>{{this.category}}</td>
                <td>{{this.brand}}</td>
                <td>{{this.price}}</td>
                <td>{{this.stockQuantity}}</td>
                <td>{{this.description}}</td>
            </tr>
        {{/each}}

    </tbody>

</table>